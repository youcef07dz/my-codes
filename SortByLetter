<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Simple Sorter</title>
    <style>
        :root {
            --bg-color: #f4f4f9;
            --card-bg: #ffffff;
            --text-color: #333333;
            --btn-color: #007bff;
            --btn-hover: #0056b3;
            --border: #ddd;
        }

        /* Dark Mode Colors */
        body.dark-mode {
            --bg-color: #121212;
            --card-bg: #1e1e1e;
            --text-color: #e0e0e0;
            --btn-color: #bb86fc;
            --btn-hover: #9965f4;
            --border: #333333;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-color);
            display: flex;
            justify-content: center;
            padding: 20px;
            transition: background 0.3s, color 0.3s;
        }

        .container {
            width: 100%;
            max-width: 500px;
            background: var(--card-bg);
            padding: 20px;
            border-radius: 12px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.2);
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }

        textarea {
            width: 100%;
            height: 300px;
            padding: 12px;
            border: 1px solid var(--border);
            border-radius: 8px;
            background: var(--bg-color);
            color: var(--text-color);
            box-sizing: border-box;
            font-size: 16px;
            resize: vertical;
        }

        button {
            width: 100%;
            padding: 12px;
            margin-top: 15px;
            background-color: var(--btn-color);
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            cursor: pointer;
            transition: background 0.2s;
        }

        button:hover { background-color: var(--btn-hover); }

        .toggle-btn {
            background: none;
            border: 1px solid var(--border);
            color: var(--text-color);
            padding: 5px 10px;
            font-size: 12px;
            width: auto;
            margin: 0;
        }
    </style>
</head>
<body>

<div class="container">
    <div class="header">
        <h3>Sort Lines</h3>
        <button class="toggle-btn" onclick="toggleTheme()">Toggle Mode</button>
    </div>
    <textarea id="textData" placeholder="Paste your lines here..."></textarea>
    <button onclick="sortMyLines()">Sort Alphabetically</button>
</div>

<script>
    function sortMyLines() {
        const el = document.getElementById("textData");
        const lines = el.value.split(/\r?\n/);
        lines.sort((a, b) => a.localeCompare(b, undefined, {sensitivity: 'base'}));
        el.value = lines.join('\n');
    }

    function toggleTheme() {
        document.body.classList.toggle('dark-mode');
    }
</script>

</body>
</html>
